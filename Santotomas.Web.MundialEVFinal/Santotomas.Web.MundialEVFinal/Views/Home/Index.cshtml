@model IEnumerable<Santotomas.Web.MundialEVFinal.Models.SeleccionViewModel>
@{
    ViewBag.Title = "Dashboard Mundial";
    var selecciones = Model ?? Enumerable.Empty<Santotomas.Web.MundialEVFinal.Models.SeleccionViewModel>();
}

<div class="row mb-4 align-items-center">
    <div class="col-12">
        <h1 class="text-dark fw-bold mb-1">
            <i class="fa-solid fa-earth-americas me-2 text-gold"></i> Central de Países
        </h1>
        <p class="text-muted fs-5">Fase operativa actual: <span class="badge bg-dark text-white py-2 px-3 fw-bold">@ViewBag.FaseActual</span></p>
    </div>
</div>

<div class="row mb-5">
    <div class="col-12">
        <div class="card card-mundial p-5 text-center shadow-sm" style="background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);">
            <span class="text-muted text-uppercase fw-bold small" style="letter-spacing: 1px;">Marcador Global del Torneo</span>
            <h1 class="display-1 fw-bold text-green my-2" style="font-size: 5.5rem;">@ViewBag.GolesMundial</h1>
            <p class="text-secondary mb-0">
                <i class="fa-solid fa-circle-info me-2 text-gold"></i>Esta métrica se sincroniza dinámicamente mediante el patrón <b>Singleton</b>.
            </p>
        </div>
    </div>
</div>

<div class="row g-4">
    @foreach (var p in selecciones)
    {
        <div class="col-12 col-sm-6 col-md-4 col-lg-3 d-flex align-items-stretch">
            <div class="card card-mundial w-100 p-4 text-center d-flex flex-column justify-content-between shadow-sm bg-white">
                <div>
                    <img src="@p.UrlBandera" alt="Bandera de @p.Pais" class="mb-3 rounded shadow-sm border border-light" style="width: 80px; height: 54px; object-fit: cover;" />

                    <h4 class="text-dark fw-bold mb-1">@p.Pais</h4>
                    <span class="text-muted small d-block mb-4">@p.Continente</span>
                </div>
                <div class="py-2 px-3 rounded-pill fw-bold text-green" style="background-color: rgba(22, 163, 74, 0.1); border: 1px solid rgba(22, 163, 74, 0.2);">
                    @p.GolesTotales Goles
                </div>
            </div>
        </div>
    }
</div>