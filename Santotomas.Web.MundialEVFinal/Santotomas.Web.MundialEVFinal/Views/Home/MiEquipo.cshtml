@model IEnumerable<Santotomas.Web.MundialEVFinal.Models.JugadorViewModel>
@using System.Linq

@{
    ViewBag.Title = "Mi Selección";
    var jugadores = Model ?? Enumerable.Empty<Santotomas.Web.MundialEVFinal.Models.JugadorViewModel>();
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="text-gold fw-bold"><i class="fa-solid fa-users-gear me-2"></i> Gestión Estratégica de Plantilla</h2>
        <p class="text-muted fs-5">Los botones ejecutan el <b>Factory Method</b>. La grilla se lee desde la <b>Base de Datos</b> a través del contrato de un <b>Iterator</b>.</p>
    </div>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-6">
        <div class="card card-mundial p-4 text-center">
            <div class="p-3 rounded-circle bg-dark d-inline-block mx-auto mb-3" style="width: 70px; height: 70px;">
                <i class="fa-solid fa-hands-holding-circle fa-2x text-gold"></i>
            </div>
            <h4 class="text-white fw-bold">Módulo Guardametas</h4>
            <p class="text-muted small">Instancia un arquero con características de reacción nativas.</p>
            <form action="@Url.Action("ConvocarJugador", "Home")" method="post" class="mt-3">
                <input type="hidden" name="tipoPosicion" value="Arquero" />
                <button type="submit" class="btn btn-outline-warning w-100 fw-bold py-2">Convocar Arquero</button>
            </form>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card card-mundial p-4 text-center" style="border-top-color: #2ea043;">
            <div class="p-3 rounded-circle bg-dark d-inline-block mx-auto mb-3" style="width: 70px; height: 70px;">
                <i class="fa-solid fa-bolt fa-2x text-green"></i>
            </div>
            <h4 class="text-white fw-bold">Módulo Ofensivo</h4>
            <p class="text-muted small">Genera un atacante configurado con lógicas de disparo a puerta.</p>
            <form action="@Url.Action("ConvocarJugador", "Home")" method="post" class="mt-3">
                <input type="hidden" name="tipoPosicion" value="Delantero" />
                <button type="submit" class="btn btn-success text-dark w-100 fw-bold py-2">Convocar Delantero</button>
            </form>
        </div>
    </div>
</div>

<div class="card card-mundial shadow-lg overflow-hidden" style="border-top-color: #58a6ff;">
    <div class="card-header border-bottom border-dark py-3 d-flex justify-content-between align-items-center" style="background-color: #1f242c;">
        <h5 class="mb-0 text-gold fw-bold"><i class="fa-solid fa-clipboard-list me-2"></i> Jugadores en la Cancha</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0 align-middle">
            <thead>
                <tr style="background-color: #0d1117;">
                    <th class="border-0 px-4 py-3 text-light fw-bold" style="width: 15%;">DORSAL</th>
                    <th class="border-0 py-3 text-light fw-bold">JUGADOR</th>
                    <th class="border-0 px-4 py-3 text-light text-end fw-bold">ROL EN EL CAMPO</th>
                </tr>
            </thead>
            <tbody>
                @Html.Raw(string.Join("", jugadores.Select(j => $@"
                    <tr class='border-bottom border-dark'>
                        <td class='px-4 fw-bold text-green fs-5'>#{j.Dorsal}</td>
                        <td class='fw-semibold text-white fs-5'>{j.Nombre}</td>
                        <td class='px-4 text-end'>
                            <span class='badge badge-posicion px-3 py-2 fw-bold fs-6'>
                                {j.Posicion}
                            </span>
                        </td>
                    </tr>
                ")))
            </tbody>
        </table>
    </div>
</div>